# ============================================================
# NutriTrack Environment Variables
# ============================================================

# Supabase (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase (private — server-side only, NEVER expose to the client)
# Used for admin operations that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (private — server-side only)
OPENAI_API_KEY=your_openai_api_key

# NextAuth (private — server-side only)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
